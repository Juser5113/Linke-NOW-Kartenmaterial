#!/bin/sh
# js/map.js, every js/config/*.js file and css/style.css share one global
# ?v= version number across all HTML files. Whenever any of them is bumped
# anywhere, the highest version found wins and gets written back to every
# occurrence of any of these files in every HTML file (adding ?v=... if an
# occurrence doesn't have one yet).

set -e

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

html_files=$(git ls-files '*.html')
[ -z "$html_files" ] && exit 0

paths='(js/map\.js|js/config/[A-Za-z0-9_-]+\.js|css/style\.css)'
pattern="${paths}\\?v=[0-9]+(\\.[0-9]+)*"

versions=$(grep -ohE "$pattern" $html_files 2>/dev/null | sed -E 's/.*\?v=//') || true
[ -z "$versions" ] && exit 0

max_version=$(printf '%s\n' "$versions" | sort -V | tail -1)

changed=0
for f in $html_files; do
    sed -i -E "s#${paths}\\?v=[0-9]+(\\.[0-9]+)*#\\1?v=${max_version}#g" "$f"
    sed -i -E "s#${paths}\"#\\1?v=${max_version}\"#g" "$f"
    if ! git diff --quiet -- "$f"; then
        git add "$f"
        changed=1
        echo "pre-commit: synced $f to v$max_version"
    fi
done

if [ "$changed" -eq 1 ]; then
    echo "pre-commit: version numbers synced to v$max_version, staged changes updated."
fi

exit 0
